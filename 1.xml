<Content type="html"><![CDATA[

<!DOCTYPE html>
<html lang="en-us">
<head>
<meta charset="utf-8"/>
<meta http-equiv="Content-Type" content="text/html; charset=utf-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no"/>
<style>
    *, html, body { padding:0; margin:0; box-sizing:border-box; }
    html, body {
        overflow: hidden;
        height: 100%;
        background: #000;
        -webkit-user-select: none; user-select: none;
        -webkit-tap-highlight-color: rgba(0,0,0,0);
    }
    canvas:focus { outline: none; }
    #unity-container { width:100%; height:100%; }
    #unity-canvas   { width:100%; height:100%; display:block; }

    /* Loading UI */
    #loading-cover {
        position: fixed; inset: 0;
        display: flex; flex-direction: column;
        align-items: center; justify-content: center;
        background: #1a1a2e; z-index: 100;
    }
    #loading-cover.hidden { display: none; }

    #load-label {
        color: #ccc; font-family: sans-serif;
        font-size: 14px; margin-bottom: 16px;
    }
    #bar-wrap {
        width: 260px; height: 8px;
        background: #333; border-radius: 4px; overflow: hidden;
    }
    #bar-fill {
        height: 100%; width: 0%;
        background: linear-gradient(90deg,#4e9af1,#a78bfa);
        border-radius: 4px;
        transition: width .25s ease;
    }
</style>
</head>
<body>
<div id="unity-container">
    <canvas id="unity-canvas" tabindex="-1"></canvas>
</div>

<div id="loading-cover">
    <div id="load-label">G+ - loading… 0%</div>
    <div id="bar-wrap"><div id="bar-fill"></div></div>
</div>

<script>
/* ============================================================
   PART CONFIG  –  PowerShell sonucuna gore guncelle
   ============================================================ */
const DATA_PARTS = 6;   // Build.data.br
const WASM_PARTS = 5;   // Build.wasm.br
const BUILD_URL  = "https://cdn.jsdelivr.net/gh/emrsdahclassroom/x7gy7@main/Build";

/* ============================================================
   YSDK STUB  –  tum fonksiyonlar bos / olumlu donduruyor
   ============================================================ */
const NO_DATA      = "no data";
let ygGameInstance = null;

/* Unity framework'un global olarak beklediği degiskenler */
var initYSDK  = true;   // _IsInitSDK_js bunu kontrol ediyor

function LogStyledMessage(msg, style) {
    console.log('%c' + msg, style || 'color:#FFDF73;background:#454545');
}
var initGame  = false;
var ysdk      = null;
var player    = null;
var cloudSaves    = NO_DATA;
var paymentsData  = NO_DATA;
var playerData    = NO_DATA;

function YG2Instance(method, arg) {
    if (!ygGameInstance) return;
    try {
        if (arg !== undefined) ygGameInstance.SendMessage("YG2Instance", method, arg);
        else                   ygGameInstance.SendMessage("YG2Instance", method);
    } catch(e) {}
}

/* Hepsini stub yap */
function SaveCloud()        {}
function LoadCloud()        { YG2Instance("SetLoadSaves", NO_DATA); return Promise.resolve(NO_DATA); }
function StickyAdActivity() {}
function RewardedAdvShow(id){ YG2Instance("OpenRewardedAdv"); YG2Instance("RewardAdv", id); YG2Instance("CloseRewardedAdv"); }
function InterAdvShow()     { YG2Instance("OpenInterAdv"); YG2Instance("CloseInterAdv","true"); }
function SetLeaderboard()   {}
function GetLeaderboard(name){ YG2Instance("LeaderboardEntries", JSON.stringify({ entries:"no data", ranks:[], photos:[], names:[], scores:[], uniqueIDs:[], extraDataArray:[] })); }
function BuyPayments(id)    { YG2Instance("OnPurchaseFailed", id); }
function ConsumePurchase()  {}
function ConsumePurchases() {}
function OpenAuthDialog()   {}
function InitPayments()     { YG2Instance("PaymentsEntries", NO_DATA); return Promise.resolve(NO_DATA); }
function InitPlayer()       {
    const j = JSON.stringify({ playerAuth:"rejected", playerName:"unauthorized", playerId:"unauthorized", playerPhoto:"no data", payingStatus:"unknown" });
    YG2Instance("SetAuth", j);
    return Promise.resolve(j);
}
function InitGame() { initGame = true; }

/* ============================================================
   PART LOADER  –  parcalari indir, birlestir, Blob URL ver
   ============================================================ */
const label   = document.getElementById("load-label");
const barFill = document.getElementById("bar-fill");
const cover   = document.getElementById("loading-cover");

function setProgress(pct, text) {
    barFill.style.width = pct + "%";
    label.textContent   = text;
}

async function fetchParts(baseName, count, startPct, endPct) {
    const chunks = [];
    const step   = (endPct - startPct) / count;
    for (let i = 0; i < count; i++) {
        const url  = `${BUILD_URL}/${baseName}.part${i}`;
        const resp = await fetch(url);
        if (!resp.ok) throw new Error(`Fetch failed: ${url}`);
        const buf  = await resp.arrayBuffer();
        chunks.push(new Uint8Array(buf));
        setProgress(Math.round(startPct + step * (i + 1)), `${baseName} loaded… G+ ${i+1}/${count}`);
    }
    /* Birlestir */
    const total  = chunks.reduce((s, c) => s + c.length, 0);
    const merged = new Uint8Array(total);
    let   offset = 0;
    for (const c of chunks) { merged.set(c, offset); offset += c.length; }
    return URL.createObjectURL(new Blob([merged]));
}

async function fetchText(url) {
    const r = await fetch(url);
    if (!r.ok) throw new Error(`Fetch failed: ${url}`);
    return r.text();
}

(async () => {
    try {
        setProgress(0, "wait…");

        /* data + wasm paralel indir */
        const [dataUrl, wasmUrl] = await Promise.all([
            fetchParts("Build.data.br",  DATA_PARTS, 0,  55),
            fetchParts("Build.wasm.br",  WASM_PARTS, 55, 90),
        ]);

        setProgress(92, "Framework yükleniyor…");
        const frameworkUrl = `${BUILD_URL}/Build.framework.js`;

        setProgress(95, "game opened…");

        /* Unity loader */
        const loaderScript = document.createElement("script");
        loaderScript.src = `${BUILD_URL}/Build.loader.js`;
        loaderScript.onload = () => {
            setProgress(98, "waitttt…");

            const canvas    = document.getElementById("unity-canvas");
            const config    = {
                dataUrl:             dataUrl,
                frameworkUrl:        frameworkUrl,
                codeUrl:             wasmUrl,
                streamingAssetsUrl:  "StreamingAssets",
                companyName:         "DefaultCompany",
                productName:         "Rampa VS Police",
                productVersion:      "0.1",
            };
            if (/iPhone|iPad|iPod|Android/i.test(navigator.userAgent))
                config.devicePixelRatio = 1.5;

            createUnityInstance(canvas, config, p => {
                setProgress(Math.round(98 + p * 2), "loaded…");
            }).then(inst => {
                ygGameInstance = inst;
                cover.classList.add("hidden");

                /* SDK init tamamlandi sinyali */
                setTimeout(() => YG2Instance("InitSDKComplete"), 300);
                setTimeout(() => {
                    InitGame();
                    YG2Instance("SetAuth",        JSON.stringify({ playerAuth:"rejected", playerName:"unauthorized", playerId:"unauthorized", playerPhoto:"no data", payingStatus:"unknown" }));
                    YG2Instance("SetLoadSaves",   NO_DATA);
                    YG2Instance("PaymentsEntries", NO_DATA);
                }, 600);

                canvas.focus();
            }).catch(e => {
                label.textContent = "Hata: " + e;
                console.error(e);
            });
        };
        document.body.appendChild(loaderScript);

    } catch (err) {
        label.textContent = "Yükleme hatası: " + err.message;
        console.error(err);
    }
})();

/* Pointer lock fix */
const oPRL = Element.prototype.requestPointerLock;
Element.prototype.requestPointerLock = async function(...args) {
    try { (args[0] ||= {}).unadjustedMovement = true; await oPRL.apply(this, args); } catch(e) {}
};

/* Context menu kapat */
document.addEventListener("contextmenu", e => e.preventDefault());
</script>
<!-- Sticky Bottom Center Ad (728x90) with Smooth Slide-Out and Reappearance -->
<style>
  /* Container: Bottom center, fixed, with overflow hidden */
  #ad-container {
    position: fixed;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: min(728px, calc(100% - 20px)); /* 728px, 10px margin on mobile */
    height: 90px;
    background: rgba(0, 0, 0, 0.90);
    display: none;
    z-index: 99999;
    border-radius: 0; /* Sharp corners */
    overflow: hidden;
    box-shadow: 0 -2px 12px rgba(0, 0, 0, 0.45);
    box-sizing: border-box;
    transition: transform 0.5s ease-in-out; /* Smooth slide-in/out animation */
  }

  /* Slide-out animation */
  #ad-container.hidden {
    transform: translate(-50%, 100%); /* Slide down out of view */
  }

  #ad-iframe {
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 745px; /* Updated width */
    height: 90px; /* Updated height */
    border: 0;
    display: block;
    overflow: hidden;
    pointer-events: auto;
    box-sizing: content-box;
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
  
  #ad-iframe::-webkit-scrollbar {
    display: none;
    width: 0;
    height: 0;
  }

  /* Close button with arrow */
  #close-ad {
    position: absolute;
    top: 6px;
    right: 8px;
    background: #ff4d4d;
    color: #fff;
    border: none;
    padding: 5px 9px;
    font-size: 13px;
    border-radius: 4px;
    cursor: not-allowed;
    opacity: 0.72;
    z-index: 100000;
    display: flex;
    align-items: center;
  }
  #close-ad.enabled {
    cursor: pointer;
    opacity: 1;
  }
  #close-ad::before {
    content: '↓'; /* Down arrow for bottom ad */
    margin-right: 4px;
  }

  /* Right mask for scrollbar */
  #ad-right-mask {
    position: absolute;
    top: 0;
    right: 0;
    width: 12px;
    height: 100%;
    pointer-events: none;
    background: linear-gradient(to right, rgba(0, 0, 0, 0), rgba(0, 0, 0, 0.9));
    z-index: 99999;
  }

  /* Mobile adjustments */
  @media (max-width: 440px) {
    #ad-container {
      width: calc(100% - 12px);
      left: 50%;
      transform: translateX(-50%);
      border-radius: 0; /* Sharp corners on mobile */
    }
    #ad-iframe {
      width: 728px;
    }
  }
</style>

<div id="ad-container" aria-hidden="true" role="dialog" aria-label="Advertisement">
  <iframe
    id="ad-iframe"
    src="https://script.google.com/macros/s/AKfycbzA6GNdpfUShkCh6apD0D21YAUf7A5d3Guhq2PayqLbk_5XG_wQhy0bdYzKJWLhzgMVMQ/exec"
    width="768px"
    height="95px"
    scrolling="no"
    frameborder="0"
    sandbox="allow-scripts allow-popups allow-same-origin"
  ></iframe>
  <button id="close-ad" disabled>Close (12)</button>
  <div id="ad-right-mask"></div>
</div>

<script>
  (function () {
    const showDelay = 2000; // 2 seconds delay before first show
    const countdownStart = 12; // 12 seconds countdown
    const reappearDelay = 150000; // 25 seconds before reappearance
    const adContainer = document.getElementById('ad-container');
    const closeBtn = document.getElementById('close-ad');

    function showAd() {
      // Show ad with smooth slide-in
      adContainer.style.display = 'block';
      adContainer.classList.remove('hidden');
      adContainer.setAttribute('aria-hidden', 'false');

      // Start countdown
      let timeLeft = countdownStart;
      closeBtn.textContent = `Close (${timeLeft})`;
      closeBtn.disabled = true;
      closeBtn.classList.remove('enabled');

      const t = setInterval(() => {
        timeLeft--;
        if (timeLeft > 0) {
          closeBtn.textContent = `Close (${timeLeft})`;
        } else {
          clearInterval(t);
          closeBtn.disabled = false;
          closeBtn.classList.add('enabled');
          closeBtn.textContent = 'Close ↓';
        }
      }, 1000);
    }

    // Initial ad show
    setTimeout(showAd, showDelay);

    // Close with animation and schedule reappearance
    closeBtn.addEventListener('click', () => {
      if (closeBtn.disabled) return;
      adContainer.classList.add('hidden');
      adContainer.setAttribute('aria-hidden', 'true');
      // Schedule reappearance without removing or reloading iframe
      setTimeout(showAd, reappearDelay);
    });
  })();
</script>
</body>
</html>


